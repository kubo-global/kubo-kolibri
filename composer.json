{
    "name": "kubo-global/kubo-kolibri",
    "description": "Curriculum-mapped bridge between KUBO and Kolibri",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shane Deconinck",
            "email": "shane.deconinck@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "KuboKolibri\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KuboKolibri\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KuboKolibri\\KuboKolibriServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
